{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"}[5m]))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"})",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Network RX",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"}[5m]))",
          "legendFormat": "{{name}} RX"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Network TX",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"}[5m]))",
          "legendFormat": "{{name}} TX"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Memory Usage Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"})",
          "legendFormat": "{{name}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Top 10 Containers by CPU",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "topk(10, sum by (name, container_label_com_docker_swarm_service_name) (rate(container_cpu_usage_seconds_total{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"}[5m])))",
          "legendFormat": "{{name}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "name": "Container",
              "container_label_com_docker_swarm_service_name": "Service",
              "Value": "CPU Usage"
            }
          }
        }
      ]
    },
    {
      "title": "CPU Usage Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"}[5m]))",
          "legendFormat": "Total CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "Memory Usage Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\",name=~\"$container\"})",
          "legendFormat": "Total Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10737418240 },
              { "color": "red", "value": 21474836480 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docker", "containers", "metrics"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
        "query": "label_values(container_cpu_usage_seconds_total{container_label_com_docker_stack_namespace=\"twir\"}, container_label_com_docker_swarm_service_name)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Service",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
        "query": "label_values(container_cpu_usage_seconds_total{container_label_com_docker_stack_namespace=\"twir\",container_label_com_docker_swarm_service_name=~\"$service\"}, name)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Container",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Docker Containers - Metrics",
  "uid": "docker-metrics",
  "version": 4
}
