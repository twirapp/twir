{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "service:* | stats count(*) by service",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "level:error | stats count(*) by service",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Total Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "* | stats count(*)",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Error Count (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "level:error | stats count(*)",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Warning Count (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "level:warn | stats count(*)",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Top Services by Log Volume",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 8 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "* | stats count(*) by service",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victoria-logs" },
      "targets": [
        {
          "expr": "level:error",
          "queryType": "raw"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["logs", "victoria-logs"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
