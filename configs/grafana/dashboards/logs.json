{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "PD775F2863313E6C7" },
      "targets": [
        {
          "expr": "label.com.docker.swarm.service.name:$service _msg:~`.*$word_filter.*`",
          "queryType": "instant"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Log Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "PD775F2863313E6C7" },
      "targets": [
        {
          "expr": "label.com.docker.swarm.service.name:$service | stats by (label.com.docker.swarm.service.name) count()",
          "queryType": "statsRange"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Error Count (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "PD775F2863313E6C7" },
      "targets": [
        {
          "expr": "label.com.docker.swarm.service.name:$service (error OR ERR) | stats count()",
          "queryType": "stats"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Warning Count (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "PD775F2863313E6C7" },
      "targets": [
        {
          "expr": "label.com.docker.swarm.service.name:$service warn | stats count()",
          "queryType": "stats"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 28 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "PD775F2863313E6C7" },
      "targets": [
        {
          "expr": "label.com.docker.swarm.service.name:$service | stats count()",
          "queryType": "stats"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Top Services by Log Volume",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "PD775F2863313E6C7" },
      "targets": [
        {
          "expr": "* | stats by (label.com.docker.swarm.service.name) count()",
          "queryType": "stats"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    }
  ],
