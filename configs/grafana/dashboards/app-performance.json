{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (service_name, http_request_method) (rate(traces_span_metrics_calls_total{http_request_method!=\"\"}[5m]))",
          "legendFormat": "{{service_name}} {{http_request_method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(traces_span_metrics_duration_milliseconds_bucket{http_request_method!=\"\"}[5m])))",
          "legendFormat": "{{service_name}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "DB Query Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (service_name, db_system, db_operation_name) (rate(traces_span_metrics_calls_total{db_system!=\"\"}[5m]))",
          "legendFormat": "{{service_name}} {{db_system}} {{db_operation_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "DB Query Duration (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "sum by (service_name, db_system, db_operation_name) (rate(traces_span_metrics_duration_milliseconds_sum{db_system!=\"\"}[5m])) / sum by (service_name, db_system, db_operation_name) (rate(traces_span_metrics_duration_milliseconds_count{db_system!=\"\"}[5m]))",
          "legendFormat": "{{service_name}} {{db_system}} {{db_operation_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
