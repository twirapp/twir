{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Search by Trace ID",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Paste a **Trace ID** below to jump directly to a trace. Use the **Explore** page with VictoriaTraces datasource for detailed trace inspection with flame graph."
      }
    },
    {
      "title": "Trace Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 3 },
      "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
      "targets": [
        {
          "queryType": "search",
          "service": "$service",
          "operation": "$operation",
          "limit": 100,
          "minDuration": "$min_duration",
          "maxDuration": "$max_duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": ["count"]
          }
        }
      ]
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
      "targets": [
        {
          "queryType": "search",
          "service": "$service",
          "operation": "$operation",
          "limit": 50,
          "minDuration": "$min_duration",
          "maxDuration": "$max_duration",
          "tags": "$error_only == 'true' ? 'error=true' : ''"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "StartTime", "desc": true }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TraceID" },
            "properties": [
              { "id": "links", "value": [
                {
                  "title": "View Trace",
                  "url": "/explore?panes={\"trace\":{\"datasource\":\"P14D5514F5CCC0D1C\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceID\",\"traceId\":\"${__value.text}\"}],\"range\":{\"from\":\"now-1h\",\"to\":\"now\"}}}&schemaVersion=1",
                  "targetBlank": true
                }
              ]},
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ServiceName" },
            "properties": [
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "OperationName" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [
              { "id": "unit", "value": "ns" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "StartTime" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "traceName": true },
            "renameByName": {
              "traceID": "TraceID",
              "serviceName": "ServiceName",
              "operationName": "OperationName",
              "duration": "Duration",
              "startTime": "StartTime"
            }
          }
        }
      ]
    },
    {
      "title": "Error Traces (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
      "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
      "targets": [
        {
          "queryType": "search",
          "service": "$service",
          "operation": "$operation",
          "limit": 1,
          "tags": "error=true"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["count"] }
      }
    },
    {
      "title": "Slow Traces (>1s, last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
      "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
      "targets": [
        {
          "queryType": "search",
          "service": "$service",
          "operation": "$operation",
          "limit": 1,
          "minDuration": "1s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["count"] }
      }
    },
    {
      "title": "Traces with >5s Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 25 },
      "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
      "targets": [
        {
          "queryType": "search",
          "service": "$service",
          "operation": "$operation",
          "limit": 1,
          "minDuration": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["count"] }
      }
    },
    {
      "title": "Total Traces (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 25 },
      "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
      "targets": [
        {
          "queryType": "search",
          "service": "$service",
          "operation": "$operation",
          "limit": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["count"] }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["traces", "jaeger", "victoria-traces"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
        "query": "services",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": "",
        "label": "Service",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "operation",
        "type": "query",
        "datasource": { "type": "jaeger", "uid": "P14D5514F5CCC0D1C" },
        "query": "operations($service)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": "",
        "label": "Operation",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "min_duration",
        "type": "custom",
        "query": ",100ms,500ms,1s,5s,10s,30s",
        "current": { "text": "", "value": "" },
        "options": [
          { "text": "Any", "value": "", "selected": true },
          { "text": "100ms", "value": "100ms" },
          { "text": "500ms", "value": "500ms" },
          { "text": "1s", "value": "1s" },
          { "text": "5s", "value": "5s" },
          { "text": "10s", "value": "10s" },
          { "text": "30s", "value": "30s" }
        ],
        "label": "Min Duration"
      },
      {
        "name": "max_duration",
        "type": "custom",
        "query": ",1s,5s,10s,30s,1m",
        "current": { "text": "", "value": "" },
        "options": [
          { "text": "Any", "value": "", "selected": true },
          { "text": "1s", "value": "1s" },
          { "text": "5s", "value": "5s" },
          { "text": "10s", "value": "10s" },
          { "text": "30s", "value": "30s" },
          { "text": "1m", "value": "1m" }
        ],
        "label": "Max Duration"
      },
      {
        "name": "error_only",
        "type": "custom",
        "query": "false,true",
        "current": { "text": "false", "value": "false" },
        "options": [
          { "text": "All traces", "value": "false", "selected": true },
          { "text": "Errors only", "value": "true" }
        ],
        "label": "Show"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Distributed Traces",
  "uid": "docker-traces",
  "version": 2
}
