sources:
  docker:
    type: docker_logs

sinks:
  victoria_logs:
    type: elasticsearch
    inputs:
      - docker
    endpoints:
      - "http://OBSERVABILITY_SERVER_IP:9428/insert/elasticsearch/"
    api_version: v8
    compression: gzip
    healthcheck:
      enabled: false
    query:
      _msg_field: message
      _time_field: timestamp
      _stream_fields: "host,container_name"
