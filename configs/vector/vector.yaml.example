sources:
  docker:
    type: docker_logs
    include_labels:
      - com.docker.stack.namespace
      - com.docker.service.name

transforms:
  enrich:
    type: remap
    inputs:
      - docker
    source: |
      .stack = .label."com.docker.stack.namespace" ?? "unknown"
      .service = .label."com.docker.service.name" ?? .container_name ?? "unknown"

sinks:
  victoria_logs:
    type: elasticsearch
    inputs:
      - enrich
    endpoints:
      - "http://OBSERVABILITY_SERVER_IP:9428/insert/elasticsearch/"
    api_version: v8
    compression: gzip
    healthcheck:
      enabled: false
    query:
      _msg_field: message
      _time_field: timestamp
      _stream_fields: "host,stack,service,container_name"
