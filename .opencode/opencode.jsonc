{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"*": "allow",
	},
	"mcp": {
		"bun": {
			"type": "local",
			"command": ["bunx", "-y", "mcp-bun@latest"],
			"environment": {
				"DISABLE_NOTIFICATIONS": "true",
			},
			"enabled": true,
		},
		"shadcnVue": {
			"type": "local",
			"enabled": true,
			"command": ["bunx", "shadcn-vue@latest", "mcp"],
		},
		"postgres": {
			"type": "local",
			"enabled": true,
			"command": [
				"bunx",
				"-y",
				"@modelcontextprotocol/server-postgres",
				"postgres://twir:twir@127.0.0.1:6432/twir?sslmode=disable",
			],
		},
		"postgres-prod": {
			"type": "local",
			"enabled": true,
			"command": ["bunx", "-y", "@modelcontextprotocol/server-postgres", "{file:.pg-prod-url}"],
		},
		"codegraph": {
			"type": "local",
			"command": ["bunx", "-y", "codegraph", "serve", "--mcp"],
			"enabled": true,
		},
		"grepApp": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true,
		},
		"redis": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"REDIS_HOST",
				"-e",
				"REDIS_PORT",
				"-e",
				"REDIS_USERNAME",
				"-e",
				"REDIS_SSL",
				"-e",
				"REDIS_CA_PATH",
				"-e",
				"REDIS_SSL_KEYFILE",
				"-e",
				"REDIS_SSL_CERTFILE",
				"-e",
				"REDIS_CERT_REQS",
				"-e",
				"REDIS_CA_CERTS",
				"-e",
				"REDIS_CLUSTER_MODE",
				"-e",
				"REDIS_PWD",
				"mcp/redis",
			],
			"environment": {
				"REDIS_HOST": "127.0.0.1",
				"REDIS_PORT": "6385",
				"REDIS_USERNAME": "default",
				"REDIS_SSL": "False",
				"REDIS_CA_PATH": "",
				"REDIS_SSL_KEYFILE": "",
				"REDIS_SSL_CERTFILE": "",
				"REDIS_CERT_REQS": "required",
				"REDIS_CA_CERTS": "",
				"REDIS_CLUSTER_MODE": "False",
				"REDIS_PWD": "",
			},
		},
	},
}
