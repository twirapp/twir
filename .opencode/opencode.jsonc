{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
  },
  "mcp": {
    "bun": {
      "type": "local",
      "command": ["bunx", "-y", "mcp-bun@latest"],
      "environment": {
        "DISABLE_NOTIFICATIONS": "true",
      },
      "enabled": true,
    },
    "shadcnVue": {
      "type": "local",
      "enabled": true,
      "command": ["bunx", "shadcn-vue@latest", "mcp"],
    },
    "postgres": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgres://twir:twir@127.0.0.1:6432/twir?sslmode=disable",
      ],
    },
    "postgres-prod": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{file:.pg-prod-url}",
      ],
    },
    "codegraph": {
      "type": "local",
      "command": ["bunx", "-y", "codegraph", "serve", "--mcp"],
      "enabled": true,
    },
    "grepApp": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
    },
  },
}
